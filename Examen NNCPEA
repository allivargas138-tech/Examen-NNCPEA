<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Examen NNCPEA</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f8fafc;
color:#1e293b;
}

header{
background:#ec4899;
color:white;
padding:25px;
text-align:center;
}

.container{
width:90%;
max-width:1200px;
margin:auto;
padding:20px;
}

.card{
background:white;
padding:20px;
border-radius:15px;
box-shadow:0 2px 10px rgba(0,0,0,.1);
margin-bottom:20px;
}

h2{
margin-bottom:15px;
}

.flashcard{
min-height:120px;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
font-size:20px;
padding:20px;
background:#fce7f3;
border-radius:10px;
cursor:pointer;
}

button{
padding:12px 20px;
border:none;
border-radius:10px;
background:#ec4899;
color:white;
font-weight:bold;
cursor:pointer;
margin-top:10px;
}

button:hover{
opacity:.9;
}

.option{
padding:12px;
margin-top:10px;
background:#e2e8f0;
border-radius:10px;
cursor:pointer;
}

.option:hover{
background:#cbd5e1;
}

.correct{
background:#22c55e !important;
color:white;
}

.wrong{
background:#ef4444 !important;
color:white;
}

.metric{
font-size:32px;
font-weight:bold;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
}
</style>

</head>
<body>

<header>
<h1>📚 Examen NNCPEA</h1>
<p>Preescolar • Escolar • Adolescente</p>
</header>

<div class="container">

<div class="grid">

<div class="card">
<h2>Preguntas Respondidas</h2>
<div id="answered" class="metric">0</div>
</div>

<div class="card">
<h2>Correctas</h2>
<div id="correct" class="metric">0</div>
</div>

<div class="card">
<h2>Precisión</h2>
<div id="accuracy" class="metric">0%</div>
</div>

</div>

<div class="card">

<h2>🧠 Flashcards</h2>

<div id="flashcard" class="flashcard">
Toca para comenzar
</div>

<button onclick="nextCard()">
Siguiente
</button>

</div>

<div class="card">

<h2>📝 Simulador de Examen</h2>

<div id="quizContainer"></div>

<button onclick="loadQuestion()">
Nueva Pregunta
</button>

</div>

</div>

<script>

let stats={
answered:0,
correct:0
};

function updateDashboard(){

document.getElementById("answered").innerText=
stats.answered;

document.getElementById("correct").innerText=
stats.correct;

let acc=0;

if(stats.answered>0){
acc=((stats.correct/stats.answered)*100).toFixed(1);
}

document.getElementById("accuracy").innerText=
acc+"%";
}

const flashcards=[

{
q:"Indicador nutricional en adolescentes",
a:"IMC para la edad"
},

{
q:"Principal deficiencia en adolescencia",
a:"Hierro"
},

{
q:"Micronutrientes importantes",
a:"Hierro, Calcio, Zinc y Vitamina D"
},

{
q:"Desnutrición crónica",
a:"Talla baja para la edad"
},

{
q:"Desnutrición aguda",
a:"Bajo peso para la talla"
},

{
q:"Preescolar",
a:"2 a 5 años"
},

{
q:"Escolar",
a:"6 a 11 años"
},

{
q:"Adolescencia",
a:"10 a 19 años"
}

];

let cardIndex=0;
let showingAnswer=false;

const flash=
document.getElementById("flashcard");

flash.addEventListener("click",()=>{

if(!showingAnswer){

flash.innerHTML=
flashcards[cardIndex].a;

showingAnswer=true;

}

});

function nextCard(){

cardIndex++;

if(cardIndex>=flashcards.length){
cardIndex=0;
}

showingAnswer=false;

flash.innerHTML=
flashcards[cardIndex].q;

}

const questions=[

{
question:"¿Cuál es el indicador recomendado para evaluar adolescentes?",
options:[
"Peso para edad",
"Talla para edad",
"IMC para edad",
"Perímetro cefálico"
],
answer:2
},

{
question:"¿Cuál es una consecuencia de la obesidad infantil?",
options:[
"Raquitismo",
"Resistencia a la insulina",
"Escorbuto",
"Anemia megaloblástica"
],
answer:1
},

{
question:"¿Qué micronutriente requiere especial atención en adolescentes mujeres?",
options:[
"Sodio",
"Hierro",
"Cloro",
"Yodo"
],
answer:1
},

{
question:"¿Cuál es el principal factor de riesgo para obesidad infantil?",
options:[
"Actividad física",
"Dieta equilibrada",
"Ultraprocesados y sedentarismo",
"Lactancia materna"
],
answer:2
}

];

function loadQuestion(){

const q=
questions[Math.floor(Math.random()*questions.length)];

let html=
`<h3>${q.question}</h3>`;

q.options.forEach((opt,index)=>{

html+=
`<div class="option"
onclick="checkAnswer(${index},${q.answer},this)">
${opt}
</div>`;

});

document.getElementById("quizContainer").innerHTML=
html;

}

function checkAnswer(selected,correct,element){

stats.answered++;

if(selected===correct){

stats.correct++;
element.classList.add("correct");

}else{

element.classList.add("wrong");

}

updateDashboard();

}

loadQuestion();

</script>

</body>
</html>
